@model HabitTrackerAspNetMVCWebApp.Models.Habit

@{
    ViewData["Title"] = "Delete Habit";
}

<h1 class="mb-4 text-danger">Delete Habit</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this habit?
</div>

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title mb-4">@Model.Name</h4>

        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

            <dt class="col-sm-3">Completed</dt>
            <dd class="col-sm-9">
                @if (Model.IsCompleted)
                {
                    <span class="badge text-bg-success">Yes</span>
                }
                else
                {
                    <span class="badge text-bg-secondary">No</span>
                }
            </dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>