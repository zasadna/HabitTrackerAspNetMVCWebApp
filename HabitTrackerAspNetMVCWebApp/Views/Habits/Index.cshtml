@model IEnumerable<HabitTrackerAspNetMVCWebApp.Models.Habit>
@using HabitTrackerAspNetMVCWebApp.Models
@{
    ViewData["Title"] = ViewBag.PageTitle ?? "Habits";
    bool isAdmin = ViewBag.IsAdmin ?? false;
    string selectedUserId = ViewBag.SelectedUserId as string ?? string.Empty;
    bool showingAll = ViewBag.ShowingAll ?? false;
    var habits = Model.ToList();
    var total = habits.Count;
    var active = habits.Count(h => h.Status == HabitStatus.Active);
    var completed = habits.Count(h => h.Status == HabitStatus.Completed);
}

<div class="page-intro">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0">Structured habit list with cleaner spacing, better actions, and clearer status overview.</p>
    </div>
</div>

<div class="action-row">
    @if (isAdmin)
    {
        <a href="@Url.Action("AdminUsers", "Habits")" class="btn btn-outline-dark">Admin Users</a>
        <a href="@Url.Action("Index", "Habits", new { all = true })" class="btn btn-outline-primary">All Habits</a>
        <a href="@Url.Action("Create", "Habits", new { userId = selectedUserId })" class="btn btn-primary">Create Habit</a>
        <a href="@Url.Action("CleanupOrphans", "Habits")" class="btn btn-outline-danger">Cleanup Orphans</a>
    }
    else
    {
        <a asp-action="Create" class="btn btn-primary">Create Habit</a>
    }
</div>

<div class="stats-grid mb-4">
    <div class="stat-card">
        <div class="stat-label">Records in this view</div>
        <div class="stat-value">@total</div>
        <div class="stat-hint">Current filtered list</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Active habits</div>
        <div class="stat-value">@active</div>
        <div class="stat-hint">Still in progress</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Completed habits</div>
        <div class="stat-value">@completed</div>
        <div class="stat-hint">Finished items</div>
    </div>
</div>

<section class="table-panel">
    <div class="table-panel-header">
        <div>
            <h3 class="mb-1">Habit table</h3>
            <div class="panel-note">Focused list view with cleaner row actions.</div>
        </div>
        @if (showingAll)
        {
            <span class="badge-soft badge-soft-neutral">All users</span>
        }
    </div>

    @if (!habits.Any())
    {
        <div class="empty-state">No habits found for this view.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-clean align-middle">
                <thead>
                    <tr>
                        @if (isAdmin)
                        {
                            <th>Owner</th>
                        }
                        <th>Title</th>
                        <th>Frequency</th>
                        <th>Status</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var habit in habits)
                {
                    <tr>
                        @if (isAdmin)
                        {
                            <td>@(habit.User?.Email ?? habit.UserId)</td>
                        }
                        <td>
                            <div class="habit-title-cell">@habit.Title</div>
                            @if (!string.IsNullOrWhiteSpace(habit.Description))
                            {
                                <div class="habit-subtext">@habit.Description</div>
                            }
                        </td>
                        <td>@habit.Frequency</td>
                        <td>
                            <span class="badge-soft @(habit.Status == HabitStatus.Completed ? "badge-soft-success" : "badge-soft-primary")">
                                @habit.Status
                            </span>
                        </td>
                        <td>@habit.StartDate.ToShortDateString()</td>
                        <td>@(habit.EndDate?.ToShortDateString() ?? "-")</td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@habit.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Edit" asp-route-id="@habit.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@habit.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
