@model IEnumerable<HabitTrackerAspNetMVCWebApp.Models.Habit>

@{
    ViewData["Title"] = "My Habits";
}

<h1>My Habits</h1>
<p>Is Admin: @User.IsInRole("Admin")</p>
<p>User: @User.Identity?.Name</p>
    <p>
        @if (User.IsInRole("Admin"))
            {
            <a asp-action="CleanupOrphans" class="btn btn-danger">
                Cleanup Orphans
            </a>
        }
    </p>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Habit</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You do not have any habits yet.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Frequency</th>
                <th>Status</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var habit in Model)
        {
            <tr>
                <td>@habit.Title</td>
                <td>@habit.Frequency</td>
                <td>@habit.Status</td>
                <td>@habit.StartDate.ToShortDateString()</td>
                <td>@(habit.EndDate?.ToShortDateString() ?? "-")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@habit.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@habit.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@habit.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>       
}