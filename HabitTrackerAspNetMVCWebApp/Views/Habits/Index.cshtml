@model IEnumerable<HabitTrackerAspNetMVCWebApp.Models.Habit>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "My Habits";
    bool isAdmin = ViewBag.IsAdmin ?? false;
    string selectedUserId = ViewBag.SelectedUserId as string ?? string.Empty;
    bool showingAll = ViewBag.ShowingAll ?? false;
}

<h1>@ViewData["Title"]</h1>

@if (isAdmin)
{
    <div class="mb-3 d-flex flex-wrap gap-2">
        <a href="@Url.Action("AdminUsers", "Habits")" class="btn btn-outline-dark">Admin Users</a>
        <a href="@Url.Action("Index", "Habits", new { all = true })" class="btn btn-outline-primary">All Habits</a>
        <a href="@Url.Action("Create", "Habits", new { userId = selectedUserId })" class="btn btn-primary">Create Habit</a>
        <a href="@Url.Action("CleanupOrphans", "Habits")" class="btn btn-danger">Cleanup Orphans</a>
    </div>
}
else
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Habit</a>
    </p>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        No habits found for this view.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                @if (isAdmin)
                {
                    <th>Owner</th>
                }
                <th>Title</th>
                <th>Frequency</th>
                <th>Status</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var habit in Model)
        {
            <tr>
                @if (isAdmin)
                {
                    <td>@(habit.User?.Email ?? habit.UserId)</td>
                }
                <td>@habit.Title</td>
                <td>@habit.Frequency</td>
                <td>@habit.Status</td>
                <td>@habit.StartDate.ToShortDateString()</td>
                <td>@(habit.EndDate?.ToShortDateString() ?? "-")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@habit.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@habit.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@habit.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}