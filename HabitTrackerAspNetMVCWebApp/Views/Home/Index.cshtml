@model IEnumerable<HabitTrackerAspNetMVCWebApp.Models.Habit>
@using HabitTrackerAspNetMVCWebApp.Models

@{
    var habits = Model?.ToList() ?? new List<Habit>();
    var isAuth = User.Identity?.IsAuthenticated == true;

    var totalHabits = habits.Count;
    var activeHabits = habits.Count(h => h.Status == HabitStatus.Active);
    var completedHabits = habits.Count(h => h.Status == HabitStatus.Completed);
}

@if (!isAuth)
{
    <div class="page-intro">
        <div>
            <h1>Build better habits with a cleaner system</h1>
            <p class="mb-3">
                Track your routines, stay consistent, and improve your daily life with a simple but powerful habit tracker.
            </p>

            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary me-2">Login</a>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-primary">Register</a>
        </div>
    </div>

    <div class="summary-grid home-feature-grid mt-4">
        <div class="stat-card">
            <div class="stat-label">Track habits</div>
            <div class="stat-value">📊</div>
            <div class="stat-hint">Create and manage daily routines</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Calendar view</div>
            <div class="stat-value">📅</div>
            <div class="stat-hint">See your monthly progress</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Kanban flow</div>
            <div class="stat-value">🧩</div>
            <div class="stat-hint">Move habits through stages</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Stay consistent</div>
            <div class="stat-value">🔥</div>
            <div class="stat-hint">Build long-term discipline</div>
        </div>
    </div>

    <div class="panel mt-4">
        <h3>Why use this app?</h3>
        <ul class="mb-0">
            <li>Simple and clean UI focused on productivity</li>
            <li>Personal habit tracking per user</li>
            <li>Role-based access (Admin / User)</li>
            <li>Calendar + Kanban integration</li>
        </ul>
    </div>
}
else
{
    <div class="page-intro">
        <div>
            <h1>Dashboard</h1>
            <p class="mb-0">Your personal habit tracking overview.</p>
        </div>
    </div>

    <div class="summary-grid mt-4">
        <div class="stat-card">
            <div class="stat-label">Total habits</div>
            <div class="stat-value">@totalHabits</div>
            <div class="stat-hint">All your routines</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Active habits</div>
            <div class="stat-value">@activeHabits</div>
            <div class="stat-hint">In progress</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Completed</div>
            <div class="stat-value">@completedHabits</div>
            <div class="stat-hint">Finished routines</div>
        </div>
    </div>

    <div class="panel mt-4">
        <h3>Recent habits</h3>

        @if (!habits.Any())
        {
            <div class="empty-state">You do not have any habits yet.</div>
        }
        else
        {
            <table class="table table-clean">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Frequency</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var h in habits.Take(5))
                {
                    <tr>
                        <td>@h.Title</td>
                        <td>@h.Status</td>
                        <td>@h.Frequency</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
}