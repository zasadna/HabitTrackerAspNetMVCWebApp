@model IEnumerable<HabitTrackerAspNetMVCWebApp.Models.Habit>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mb-4">
    <h1 class="display-4">Habit Tracker</h1>
    <p>Build better routines and track your progress.</p>
</div>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="mb-4">
        <a asp-controller="Habits" asp-action="Index" class="btn btn-primary">Go to My Habits</a>
        <a asp-controller="Habits" asp-action="Create" class="btn btn-success">Create Habit</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <h2 class="mb-3">Recent Habits</h2>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Frequency</th>
                    <th>Start Date</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var habit in Model)
            {
                <tr>
                    <td>@habit.Title</td>
                    <td>@habit.Status</td>
                    <td>@habit.Frequency</td>
                    <td>@habit.StartDate.ToShortDateString()</td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <p>You do not have any habits yet.</p>
    }
}
else
{
    <div class="text-center">
        <p>Please register or log in to manage your habits.</p>
        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary">Login</a>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-primary">Register</a>
    </div>
}