@{
    ViewData["Title"] = "Privacy";
}

<div class="info-grid">
    <section class="page-hero">
        <div class="text-soft mb-2">Project information</div>
        <h1>Privacy policy</h1>
        <p>
            This Habit Tracker stores user accounts, personal habits, and habit log entries that are required to provide dashboard,
            calendar, and kanban functionality.
        </p>
        <p class="mb-0">
            For a student project, keep this page simple and honest: explain what data is stored, why it is used, and that users can only
            access their own data unless they are admins.
        </p>
    </section>

    <aside class="panel">
        <h3 class="mb-3">Suggested points</h3>
        <ul class="panel-list mb-0">
            <li>User account information</li>
            <li>Habit titles and descriptions</li>
            <li>Habit completion history</li>
            <li>Role-based access control</li>
        </ul>
    </aside>
</div>
