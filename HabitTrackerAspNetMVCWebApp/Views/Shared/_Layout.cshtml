@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var isAuthPage = requestPath.StartsWith("/Identity/Account", StringComparison.OrdinalIgnoreCase);

    string NavClass(string controller, string? action = null)
    {
        var isActiveController = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var isActiveAction = string.IsNullOrWhiteSpace(action) || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return isActiveController && isActiveAction ? "sidebar-link active" : "sidebar-link";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HabitTracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("VendorStyles", required: false)
    @RenderSection("PageStyles", required: false)
</head>
<body class="app-body @(isAuthPage ? "auth-body" : string.Empty)">
    <div class="app-shell">
        <aside class="app-sidebar">
            <div>
                <a asp-controller="Home" asp-action="Index" class="app-brand">
                    <span class="app-brand-mark">HT</span>
                    <span class="app-brand-text">HabitTracker</span>
                </a>

                <nav class="sidebar-nav">
                    <a asp-controller="Home" asp-action="Index" class="@NavClass("Home", "Index")">Home</a>
                    <a asp-controller="Habits" asp-action="Index" class="@NavClass("Habits")">Habits</a>
                    <a asp-controller="Calendar" asp-action="Index" class="@NavClass("Calendar")">Calendar</a>
                    <a asp-controller="Kanban" asp-action="Index" class="@NavClass("Kanban")">Kanban</a>
                    <a asp-controller="Home" asp-action="Privacy" class="@NavClass("Home", "Privacy")">Privacy</a>
                </nav>

                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-section-title">Admin</div>
                    <nav class="sidebar-nav">
                        <a asp-controller="AdminUsers" asp-action="Index" class="@NavClass("AdminUsers")">Users</a>
                    </nav>
                }
            </div>

            <div class="sidebar-footer">
                <partial name="_LoginPartial" />
            </div>
        </aside>

        <div class="app-main">
            <header class="app-header">
                <div class="app-header-title">@ViewData["Title"]</div>
            </header>

            <main class="app-content">
                <div class="page-container @(isAuthPage ? "page-container-auth" : string.Empty)">
                    @RenderBody()
                </div>
            </main>

            <footer class="app-footer">
                <span>&copy; 2026 HabitTrackerAspNetMVCWebApp</span>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.js"></script>
    @RenderSection("VendorScripts", required: false)
    @RenderSection("PageScripts", required: false)
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>