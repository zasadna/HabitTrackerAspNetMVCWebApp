<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HabitTracker</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            background-color: #f5f7fb;
            font-family: Arial, sans-serif;
        }

        .app-shell {
            display: flex;
            min-height: 100vh;
        }

        .app-sidebar {
            width: 240px;
            background: #ffffff;
            border-right: 1px solid #e5e7eb;
            padding: 24px 16px;
            flex-shrink: 0;
        }

        .app-brand {
            display: inline-block;
            margin-bottom: 24px;
            font-size: 32px;
            font-weight: 700;
            color: #4f46e5;
            text-decoration: none;
        }

        .app-nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .app-nav a {
            display: block;
            padding: 12px 16px;
            border-radius: 10px;
            color: #111827;
            text-decoration: none;
            font-weight: 500;
        }

        .app-nav a:hover {
            background-color: #eef2ff;
            color: #4338ca;
        }

        .app-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .app-header {
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;
            padding: 20px 24px;
            font-size: 24px;
            font-weight: 600;
        }

        .app-content {
            padding: 24px;
        }

        .app-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
        }

        .app-footer {
            margin-top: auto;
            padding: 16px 24px;
            color: #6b7280;
            font-size: 14px;
        }
    </style>

    @RenderSection("VendorStyles", required: false)
    @RenderSection("PageStyles", required: false)
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <a asp-controller="Home" asp-action="Index" class="app-brand">HabitTracker</a>

            <nav class="app-nav">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Habits" asp-action="Index">Habits</a>
                <a asp-controller="Pages" asp-action="Calendar">Calendar</a>
                <a asp-controller="Pages" asp-action="Kanban">Kanban</a>
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </nav>
        </aside>

        <main class="app-main">
            <header class="app-header">
                @ViewData["Title"]
            </header>

            <section class="app-content">
                <div class="app-card">
                    @RenderBody()
                </div>
            </section>

            <footer class="app-footer">
                &copy; 2026 - HabitTrackerAspNetMVCWebApp
            </footer>
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("VendorScripts", required: false)
    @RenderSection("PageScripts", required: false)
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>