<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HabitTracker</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f5f7fb;
        }

        .app-sidebar {
            min-height: 100vh;
            background: #ffffff;
            border-right: 1px solid #e5e7eb;
            padding: 1.5rem 1rem;
        }

        .app-brand {
            font-size: 1.4rem;
            font-weight: 700;
            color: #4f46e5;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 1.5rem;
        }

        .app-nav a {
            display: block;
            padding: 0.75rem 1rem;
            margin-bottom: 0.5rem;
            color: #111827;
            text-decoration: none;
            border-radius: 0.5rem;
            font-weight: 500;
        }

        .app-nav a:hover {
            background-color: #eef2ff;
            color: #4338ca;
        }

        .app-header {
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;
            padding: 1rem 1.5rem;
            font-weight: 600;
        }

        .app-content {
            padding: 2rem;
        }

        .app-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 0.75rem;
            padding: 1.5rem;
            box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
        }

        .app-footer {
            padding: 1rem 2rem;
            color: #6b7280;
            font-size: 0.95rem;
        }
    </style>

    @RenderSection("VendorStyles", required: false)
    @RenderSection("PageStyles", required: false)
</head>
<body>
    <div class="container-fluid">
        <div class="row g-0">
            <aside class="col-md-3 col-lg-2 app-sidebar">
                <a asp-controller="Home" asp-action="Index" class="app-brand">HabitTracker</a>

                <nav class="app-nav">
                    <a asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-controller="Pages" asp-action="Calendar">Calendar</a>
                    <a asp-controller="Pages" asp-action="Kanban">Kanban</a>
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </nav>
            </aside>

            <main class="col-md-9 col-lg-10">
                <div class="app-header">
                    @ViewData["Title"]
                </div>

                <div class="app-content">
                    <div class="app-card">
                        @RenderBody()
                    </div>
                </div>

                <div class="app-footer">
                    &copy; 2026 - HabitTrackerAspNetMVCWebApp
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("VendorScripts", required: false)
    @RenderSection("PageScripts", required: false)
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>