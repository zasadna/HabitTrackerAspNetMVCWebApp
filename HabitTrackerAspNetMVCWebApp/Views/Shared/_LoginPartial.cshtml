@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="auth-panel">
        <div class="auth-user">Hello @User.Identity?.Name!</div>

        <form asp-area="Identity" asp-page="/Account/Logout" method="post">
            <button type="submit" class="auth-btn auth-btn-outline">Logout</button>
        </form>
    </div>
}
else
{
    <div class="auth-panel">
        <a class="auth-btn auth-btn-outline" asp-area="Identity" asp-page="/Account/Login">Login</a>
        <a class="auth-btn auth-btn-primary" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </div>
}